<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AGRA_EASY_MOBILE"
             x:Class="AGRA_EASY_MOBILE.RefundInvoiceListView"
             Title="Remboursements en attente"
             BackgroundColor="#F6F8FB">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:ClientOrderCodeDisplayConverter x:Key="ClientOrderCodeDisplayConverter" />
            <local:ClientOrderCodeInputTransparentConverter x:Key="ClientOrderCodeInputTransparentConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="0" Padding="10,8,10,6">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                <BoxView Grid.Column="0" WidthRequest="1" Opacity="0" />

                <HorizontalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center" VerticalOptions="Center">
                    <Border Stroke="#D9E2EC" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="7,1" MinimumHeightRequest="36" VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="13" />
                        </Border.StrokeShape>
                        <Grid WidthRequest="132" HeightRequest="36" HorizontalOptions="Fill" VerticalOptions="Fill">
                            <local:BorderlessPicker x:Name="PickerSortMode"
                                                    Title="Tri"
                                                    SelectedIndexChanged="OnSortModeChanged"
                                                    FontSize="12"
                                                    TextColor="#0F172A"
                                                    TitleColor="#64748B"
                                                    BackgroundColor="Transparent"
                                                    HorizontalOptions="Fill"
                                                    VerticalOptions="Fill"
                                                    Opacity="0.01" />
                            <Label Text="{Binding Source={x:Reference PickerSortMode}, Path=SelectedItem}"
                                   FontSize="12"
                                   TextColor="#0F172A"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Fill"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   InputTransparent="True" />
                        </Grid>
                    </Border>

                    <Border IsVisible="{Binding ShowSortDirection}" Stroke="#D9E2EC" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="0" WidthRequest="38" MinimumHeightRequest="36" VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="13" />
                        </Border.StrokeShape>
                        <Button Text="{Binding SortDirectionIcon}"
                                Clicked="OnSortDirectionToggleClicked"
                                BackgroundColor="Transparent"
                                TextColor="#0F172A"
                                FontAttributes="Bold"
                                FontSize="18"
                                Padding="0"
                                HeightRequest="34"
                                WidthRequest="36" />
                    </Border>
                </HorizontalStackLayout>

                <Border Grid.Column="2" Stroke="#D9E2EC" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="8,5" MinimumHeightRequest="36" HorizontalOptions="End" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="13" />
                    </Border.StrokeShape>
                    <Button Text="Filtre"
                            Clicked="OnOpenFilterClicked"
                            BackgroundColor="Transparent"
                            TextColor="#0F172A"
                            FontSize="12"
                            FontAttributes="Bold"
                            Padding="0"
                            HeightRequest="24" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <CollectionView x:Name="RefundWaitingCollection" Margin="12,10,12,12">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="20" HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                        <Label Text="Aucune ligne trouvée" FontSize="15" FontAttributes="Bold" TextColor="#0F172A" HorizontalTextAlignment="Center" />
                        <Label Text="Modifiez les critères de filtre si nécessaire." FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10" Padding="14,12" StrokeThickness="1" Stroke="#E2E8F0" BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="{Binding DisplayRefundWaitingCode}" FontAttributes="Bold" FontSize="15" TextColor="#16A34A" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                    <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#EEF7FF" Padding="8,4" VerticalOptions="Center" HorizontalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding DisplayWarehouseReturnType}" FontSize="11" TextColor="#2563EB" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" />
                                    </Border>
                                    <Label Grid.Column="2" Text="{Binding DisplayHeaderDate}" FontSize="12" TextColor="#64748B" VerticalOptions="Center" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="{Binding DisplayDeliveryNetPrice, StringFormat='Prix BL : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#0F172A" LineBreakMode="NoWrap" />
                                    <Label Grid.Column="1" Text="{Binding DisplayDepressions}" IsVisible="{Binding HasDepression}" FontSize="12" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" />
                                    <Label Grid.Column="2" Text="{Binding DisplayTTC, StringFormat='TTC : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#DC2626" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                </Grid>

                                <Label Text="{Binding AccountCode, StringFormat='Client : {0}'}" IsVisible="{Binding ShouldShowCustomerBlock}" FontSize="12" TextColor="#334155" LineBreakMode="TailTruncation" />

                                <BoxView HeightRequest="0.5" Color="#E5EAF0" />

                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Padding="0,2">
                                    <Label Grid.Column="0" Text="{Binding ProductCode}" FontSize="12" FontAttributes="Bold" TextColor="#16A34A" HorizontalOptions="Start" LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1" Text="{Binding DeliveryNumber, StringFormat='BL : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="2" Text="{Binding DisplayQuantity, StringFormat='Qté : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#0F172A" HorizontalTextAlignment="End" MinimumWidthRequest="64" LineBreakMode="NoWrap" />
                                </Grid>

                                <Label Text="{Binding ProductLabel}" FontSize="12" TextColor="#334155" LineBreakMode="TailTruncation" />

                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Padding="0,2">
                                    <Label Grid.Column="0" Text="{Binding ReturnClientCode, StringFormat='Cmd : {0}', Converter={StaticResource ClientOrderCodeDisplayConverter}, ConverterParameter=24}"
                                           InputTransparent="{Binding ReturnClientCode, Converter={StaticResource ClientOrderCodeInputTransparentConverter}, ConverterParameter=24}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#DC2626"
                                           LineBreakMode="TailTruncation">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnReturnClientCodeTapped" CommandParameter="{Binding ReturnClientCode}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label Grid.Column="1" Text="{Binding DisplayTVA, StringFormat='TVA : {0}'}" FontSize="11" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" />
                                    <Label Grid.Column="2" Text="{Binding DisplayLineTotal, StringFormat='Total : {0}'}" FontSize="11" FontAttributes="Bold" TextColor="#DC2626" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                </Grid>

                                <Border StyleId="ReturnClientCodePopup" IsVisible="False" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="8,5">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10" />
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnReturnClientCodeTapped" />
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding ReturnClientCode}" FontSize="11" TextColor="#0F172A" LineBreakMode="WordWrap" />
                                </Border>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid x:Name="ApiLoadingOverlay" IsVisible="False" InputTransparent="False" BackgroundColor="#80F8FAFC" ZIndex="10">
                <Border Padding="22,20" BackgroundColor="White" Stroke="#D9E2EC" StrokeThickness="1" HorizontalOptions="Center" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                        <ActivityIndicator x:Name="ApiActivityIndicator" IsVisible="False" IsRunning="False" Color="#16A34A" WidthRequest="44" HeightRequest="44" HorizontalOptions="Center" />
                        <Label Text="Chargement..." FontSize="13" FontAttributes="Bold" TextColor="#0F172A" HorizontalTextAlignment="Center" />
                        <Label Text="Veuillez patienter" FontSize="11" TextColor="#64748B" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
