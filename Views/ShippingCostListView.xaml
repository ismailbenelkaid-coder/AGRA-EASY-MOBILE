<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AGRA_EASY_MOBILE"
             x:Class="AGRA_EASY_MOBILE.ShippingCostListView"
             Title="Frais de port"
             BackgroundColor="#F6F8FB">
    <ContentPage.Resources><ResourceDictionary><local:ClientOrderCodeDisplayConverter x:Key="ClientOrderCodeDisplayConverter" /><local:ClientOrderCodeInputTransparentConverter x:Key="ClientOrderCodeInputTransparentConverter" /></ResourceDictionary></ContentPage.Resources>
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="0" Padding="10,8,10,6">
            <VerticalStackLayout Spacing="6">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                    <HorizontalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center"><CheckBox x:Name="CheckGlobalDetails" CheckedChanged="OnGlobalDetailsChanged" Color="#16A34A" VerticalOptions="Center" /><Label Text="Détail" FontSize="12" TextColor="#0F172A" VerticalTextAlignment="Center" /></HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center" VerticalOptions="Center">
                        <Border Stroke="#D9E2EC" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="7,1" MinimumHeightRequest="36" VerticalOptions="Center"><Border.StrokeShape><RoundRectangle CornerRadius="13" /></Border.StrokeShape><Grid WidthRequest="132" HeightRequest="36"><local:BorderlessPicker x:Name="PickerSortMode" Title="Tri" SelectedIndexChanged="OnSortModeChanged" FontSize="12" TextColor="#0F172A" TitleColor="#64748B" BackgroundColor="Transparent" HorizontalOptions="Fill" VerticalOptions="Fill" Opacity="0.01" /><Label Text="{Binding Source={x:Reference PickerSortMode}, Path=SelectedItem}" FontSize="12" TextColor="#0F172A" HorizontalOptions="Fill" VerticalOptions="Fill" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" InputTransparent="True" /></Grid></Border>
                        <Border IsVisible="{Binding ShowSortDirection}" Stroke="#D9E2EC" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="0" WidthRequest="38" MinimumHeightRequest="36" VerticalOptions="Center"><Border.StrokeShape><RoundRectangle CornerRadius="13" /></Border.StrokeShape><Button Text="{Binding SortDirectionIcon}" Clicked="OnSortDirectionToggleClicked" BackgroundColor="Transparent" TextColor="#0F172A" FontAttributes="Bold" FontSize="18" Padding="0" HeightRequest="34" WidthRequest="36" /></Border>
                    </HorizontalStackLayout>
                    <Border Grid.Column="2" Stroke="#D9E2EC" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="8,5" MinimumHeightRequest="36" HorizontalOptions="End" VerticalOptions="Center"><Border.StrokeShape><RoundRectangle CornerRadius="13" /></Border.StrokeShape><Button Text="Filtre" Clicked="OnOpenFilterClicked" BackgroundColor="Transparent" TextColor="#0F172A" FontSize="12" FontAttributes="Bold" Padding="0" HeightRequest="24" /></Border>
                </Grid>
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4"><HorizontalStackLayout Grid.Column="0" Spacing="0" HorizontalOptions="Center"><CheckBox x:Name="CheckWaitingLines" CheckedChanged="OnStatusFilterChanged" Color="#16A34A" /><Label Text="En attente" FontSize="11" TextColor="#0F172A" VerticalTextAlignment="Center" /></HorizontalStackLayout><HorizontalStackLayout Grid.Column="1" Spacing="0" HorizontalOptions="Center"><CheckBox x:Name="CheckBilledLines" CheckedChanged="OnStatusFilterChanged" Color="#16A34A" /><Label Text="Facturé" FontSize="11" TextColor="#0F172A" VerticalTextAlignment="Center" /></HorizontalStackLayout><HorizontalStackLayout Grid.Column="2" Spacing="0" HorizontalOptions="Center"><CheckBox x:Name="CheckExemptLines" CheckedChanged="OnStatusFilterChanged" Color="#16A34A" /><Label Text="Exonéré" FontSize="11" TextColor="#0F172A" VerticalTextAlignment="Center" /></HorizontalStackLayout></Grid>
            </VerticalStackLayout>
        </Border>
        <Grid Grid.Row="1">
            <CollectionView x:Name="ShippingCostCollection" Margin="12,10,12,12">
                <CollectionView.EmptyView><VerticalStackLayout Padding="20" HorizontalOptions="Center" VerticalOptions="Center" Spacing="8"><Label Text="Aucun frais de port trouvé" FontSize="15" FontAttributes="Bold" TextColor="#0F172A" HorizontalTextAlignment="Center" /><Label Text="Modifiez les critères de filtre si nécessaire." FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center" /></VerticalStackLayout></CollectionView.EmptyView>
                <CollectionView.ItemTemplate><DataTemplate><Border Margin="0,0,0,10" Padding="14,12" StrokeThickness="1" Stroke="#E2E8F0" BackgroundColor="White"><Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape><VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8"><Label Grid.Column="0" Text="{Binding DisplayShippingCostCode}" FontAttributes="Bold" FontSize="15" TextColor="#16A34A" VerticalOptions="Center" LineBreakMode="TailTruncation" /><Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#EEF7FF" Padding="8,4" VerticalOptions="Center" HorizontalOptions="Center"><Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape><Label Text="{Binding DisplayWarehouseShippingCostDeliveryNumber}" FontSize="11" TextColor="#2563EB" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" /></Border><Label Grid.Column="2" Text="{Binding DisplayHeaderDate}" FontSize="12" TextColor="#64748B" VerticalOptions="Center" HorizontalTextAlignment="End" LineBreakMode="NoWrap" /></Grid>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10"><Label Grid.Column="0" Text="{Binding CarrierName}" FontSize="12" FontAttributes="Bold" TextColor="#0F172A" LineBreakMode="TailTruncation" /><Label Grid.Column="1" Text="{Binding DisplayTotalWeightAndContainers}" FontSize="12" FontAttributes="Bold" TextColor="#64748B" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" /><Label Grid.Column="2" Text="{Binding DisplayCost}" FontSize="12" FontAttributes="Bold" TextColor="#DC2626" HorizontalTextAlignment="End" LineBreakMode="NoWrap" /></Grid>
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="4"><Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding DisplayAddress, Converter={StaticResource ClientOrderCodeDisplayConverter}, ConverterParameter=56}" IsVisible="{Binding HasAddress}" InputTransparent="{Binding DisplayAddress, Converter={StaticResource ClientOrderCodeInputTransparentConverter}, ConverterParameter=56}" FontSize="12" TextColor="#334155" LineBreakMode="TailTruncation"><Label.GestureRecognizers><TapGestureRecognizer Tapped="OnAddressTapped" /></Label.GestureRecognizers></Label><Label Grid.Row="1" Grid.Column="0" Text="{Binding DisplayCityZip}" FontSize="12" TextColor="#334155" LineBreakMode="TailTruncation" /><Label Grid.Row="1" Grid.Column="1" Text="{Binding DisplayAccountCode}" IsVisible="{Binding ShouldShowCustomerBlock}" FontSize="12" TextColor="#334155" HorizontalTextAlignment="End" HorizontalOptions="End" LineBreakMode="TailTruncation" /></Grid>
                    <Border StyleId="AddressPopup" IsVisible="False" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="8,5"><Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape><Border.GestureRecognizers><TapGestureRecognizer Tapped="OnAddressTapped" /></Border.GestureRecognizers><Label Text="{Binding DisplayAddress}" FontSize="11" TextColor="#0F172A" LineBreakMode="WordWrap" /></Border>
                    <Border Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="8,4" MinimumHeightRequest="32"><Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape><Grid ColumnDefinitions="*,Auto" ColumnSpacing="6" HeightRequest="24" MinimumHeightRequest="24"><Label Grid.Column="0" Text="{Binding Description}" FontSize="11" TextColor="#64748B" LineBreakMode="TailTruncation" MaxLines="1" HorizontalTextAlignment="Start" VerticalTextAlignment="Center" VerticalOptions="Center" /><Border Grid.Column="1" IsVisible="{Binding HasLongDescription}" BackgroundColor="#F1F5F9" StrokeThickness="0" WidthRequest="24" HeightRequest="22" HorizontalOptions="End" VerticalOptions="Center"><Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape><Label Text="…" TextColor="#0F172A" FontAttributes="Bold" FontSize="11" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" /><Border.GestureRecognizers><TapGestureRecognizer Tapped="OnShowFullDescriptionTapped" CommandParameter="{Binding .}" /></Border.GestureRecognizers></Border></Grid></Border>
                    <VerticalStackLayout IsVisible="{Binding Source={RelativeSource AncestorType={x:Type local:ShippingCostListView}}, Path=ShowDetailedView}" Spacing="6"><BoxView HeightRequest="0.5" Color="#E5EAF0" /><Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10" Padding="0,2"><Label Grid.Column="0" Text="{Binding DisplayContainerNo}" FontSize="12" FontAttributes="Bold" TextColor="#16A34A" HorizontalOptions="Start" LineBreakMode="TailTruncation" /><Label Grid.Column="1" Text="{Binding TurnoverDeliveryNumber, StringFormat='BL : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" /><Label Grid.Column="2" Text="{Binding DisplayWeight}" FontSize="12" FontAttributes="Bold" TextColor="#0F172A" HorizontalTextAlignment="End" LineBreakMode="NoWrap" /></Grid></VerticalStackLayout>
                </VerticalStackLayout></Border></DataTemplate></CollectionView.ItemTemplate>
            </CollectionView>
            <Grid x:Name="ApiLoadingOverlay" IsVisible="False" InputTransparent="False" BackgroundColor="#80F8FAFC" ZIndex="10"><Border Padding="22,20" BackgroundColor="White" Stroke="#D9E2EC" StrokeThickness="1" HorizontalOptions="Center" VerticalOptions="Center"><Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape><VerticalStackLayout Spacing="12" HorizontalOptions="Center"><ActivityIndicator x:Name="ApiActivityIndicator" IsVisible="False" IsRunning="False" Color="#16A34A" WidthRequest="44" HeightRequest="44" HorizontalOptions="Center" /><Label Text="Chargement..." FontSize="13" FontAttributes="Bold" TextColor="#0F172A" HorizontalTextAlignment="Center" /><Label Text="Veuillez patienter" FontSize="11" TextColor="#64748B" HorizontalTextAlignment="Center" /></VerticalStackLayout></Border></Grid>
        </Grid>
    </Grid>
</ContentPage>
