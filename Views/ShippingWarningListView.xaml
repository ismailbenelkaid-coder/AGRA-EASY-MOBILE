<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AGRA_EASY_MOBILE.ShippingWarningListView"
             Title="Alertes"
             BackgroundColor="#F6F8FB">
    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" Padding="16,12,16,8" ColumnDefinitions="*,Auto" ColumnSpacing="12" BackgroundColor="White">
            <Border Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="14,9">
                <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                <Label Text="Alertes" FontSize="16" FontAttributes="Bold" TextColor="#0F172A" HorizontalTextAlignment="Center" />
            </Border>
            <Button Grid.Column="1"
                    Text="Filtre"
                    BackgroundColor="#F8FAFC"
                    TextColor="#0F172A"
                    BorderColor="#E2E8F0"
                    BorderWidth="1"
                    CornerRadius="18"
                    HeightRequest="46"
                    WidthRequest="98"
                    Clicked="OnOpenFilterClicked" />
        </Grid>

        <Grid Grid.Row="1">
            <CollectionView x:Name="WarningsCollection"
                            ItemsSource="{Binding Warnings}"
                            Scrolled="OnWarningsCollectionScrolled"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="30" Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="Aucune alerte à afficher." FontSize="15" TextColor="#64748B" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" Padding="13,10" Margin="16,6">
                            <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnWarningTapped" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="5">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Text="{Binding DateText}" FontSize="12" TextColor="#64748B" VerticalOptions="Center" />
                                    <Border Grid.Column="1" BackgroundColor="#DCFCE7" StrokeThickness="0" Padding="7,3" IsVisible="{Binding IsNew}">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                        <Label Text="Nouveau" FontSize="10" FontAttributes="Bold" TextColor="#16A34A" />
                                    </Border>
                                </Grid>

                                <Label Grid.Row="1"
                                       Text="{Binding ShortDescription}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid x:Name="LoadingOverlay" IsVisible="False" BackgroundColor="#80F6F8FB" InputTransparent="False">
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" Color="#16A34A" WidthRequest="46" HeightRequest="46" />
                    <Label Text="Chargement des alertes..." TextColor="#64748B" FontSize="13" />
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
