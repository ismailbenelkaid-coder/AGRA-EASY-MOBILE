<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AGRA_EASY_MOBILE"
             x:Class="AGRA_EASY_MOBILE.CustomerBillingListView"
             Title="Factures client"
             BackgroundColor="#F6F8FB">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <local:ClientOrderCodeDisplayConverter x:Key="ClientOrderCodeDisplayConverter" />
            <local:ClientOrderCodeInputTransparentConverter x:Key="ClientOrderCodeInputTransparentConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="0" Padding="10,8,10,6">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                <Grid Grid.Column="0" HorizontalOptions="Start" VerticalOptions="Center">
                    <Border IsVisible="{Binding ShowDetailsToggle}"
                            Stroke="#D9E2EC"
                            StrokeThickness="1"
                            BackgroundColor="#F8FAFC"
                            Padding="6,5"
                            WidthRequest="86"
                            MinimumHeightRequest="36">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="13" />
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center" HorizontalOptions="Center">
                            <Grid WidthRequest="24" HeightRequest="24" VerticalOptions="Center" HorizontalOptions="Center">
                                <CheckBox x:Name="CheckGlobalDetails"
                                          Color="#16A34A"
                                          VerticalOptions="Center"
                                          HorizontalOptions="Center"
                                          WidthRequest="24"
                                          HeightRequest="24"
                                          Scale="0.66"
                                          CheckedChanged="OnGlobalDetailsChanged" />
                            </Grid>
                            <Label Text="Détail" VerticalOptions="Center" FontSize="11" TextColor="#0F172A" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border IsVisible="{Binding ShowBackButton}"
                            Stroke="#CFE9D8"
                            StrokeThickness="1"
                            BackgroundColor="#F2FBF5"
                            Padding="8,5"
                            MinimumHeightRequest="36">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="13" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="5">
                            <Label Text="←" FontSize="14" FontAttributes="Bold" TextColor="#16A34A" VerticalOptions="Center" />
                            <Button x:Name="BtnBack"
                                    Grid.Column="1"
                                    Text="Retour"
                                    Clicked="OnBackClicked"
                                    BackgroundColor="Transparent"
                                    TextColor="#16A34A"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    Padding="0"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </Grid>

                <HorizontalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center" VerticalOptions="Center">
                    <Border Stroke="#D9E2EC"
                            StrokeThickness="1"
                            BackgroundColor="#F8FAFC"
                            Padding="7,1"
                            MinimumHeightRequest="36"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="13" />
                        </Border.StrokeShape>
                        <Grid WidthRequest="132" HeightRequest="36" HorizontalOptions="Fill" VerticalOptions="Fill">
                            <local:BorderlessPicker x:Name="PickerSortMode"
                                                    Title="Tri"
                                                    SelectedIndexChanged="OnSortModeChanged"
                                                    FontSize="12"
                                                    TextColor="#0F172A"
                                                    TitleColor="#64748B"
                                                    BackgroundColor="Transparent"
                                                    HorizontalOptions="Fill"
                                                    VerticalOptions="Fill"
                                                    Opacity="0.01" />
                            <Label Text="{Binding Source={x:Reference PickerSortMode}, Path=SelectedItem}"
                                   FontSize="12"
                                   TextColor="#0F172A"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Fill"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   InputTransparent="True" />
                        </Grid>
                    </Border>

                    <Border IsVisible="{Binding ShowSortDirection}"
                            Stroke="#D9E2EC"
                            StrokeThickness="1"
                            BackgroundColor="#F8FAFC"
                            Padding="0"
                            WidthRequest="38"
                            MinimumHeightRequest="36"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="13" />
                        </Border.StrokeShape>
                        <Button Text="{Binding SortDirectionIcon}"
                                Clicked="OnSortDirectionToggleClicked"
                                BackgroundColor="Transparent"
                                TextColor="#0F172A"
                                FontAttributes="Bold"
                                FontSize="18"
                                Padding="0"
                                HeightRequest="34"
                                WidthRequest="36" />
                    </Border>
                </HorizontalStackLayout>

                <Border Grid.Column="2"
                        Stroke="#D9E2EC"
                        StrokeThickness="1"
                        BackgroundColor="#F8FAFC"
                        Padding="8,5"
                        MinimumHeightRequest="36"
                        HorizontalOptions="End"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="13" />
                    </Border.StrokeShape>
                    <Button Text="Filtre"
                            Clicked="OnOpenFilterClicked"
                            BackgroundColor="Transparent"
                            TextColor="#0F172A"
                            FontSize="12"
                            FontAttributes="Bold"
                            Padding="0"
                            HeightRequest="24" />
                </Border>
            </Grid>
        </Border>

        <Grid x:Name="BodyGrid" Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="0">
            <Border x:Name="SingleDetailHeaderBorder"
                    Grid.Row="0"
                    IsVisible="{Binding ShowSingleDetailHeader}"
                    BindingContext="{Binding CurrentDetailHeader}"
                    Margin="12,10,12,8"
                    Padding="14,12"
                    StrokeThickness="1"
                    Stroke="#E2E8F0"
                    BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="{Binding CustomerBillingId}" FontAttributes="Bold" FontSize="15" TextColor="#16A34A" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#EEF7FF" Padding="8,4" VerticalOptions="Center" HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <Label Text="{Binding Warehouse}" FontSize="11" TextColor="#2563EB" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" />
                        </Border>
                        <Label Grid.Column="2" Text="{Binding DisplayCreationDate}" FontSize="12" TextColor="#64748B" VerticalOptions="Center" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Label Text="{Binding DisplayTotalHTBase, StringFormat='HT : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#0F172A" LineBreakMode="NoWrap" />
                        <Label Grid.Column="1" Text="{Binding DisplayTotalTVA, StringFormat='TVA : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" />
                        <Label Grid.Column="2" Text="{Binding DisplayTotalTTC, StringFormat='TTC : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#DC2626" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                    </Grid>

                    <VerticalStackLayout Spacing="3" IsVisible="{Binding ShouldShowCustomerBlock}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label Text="{Binding DisplayDeliveredAccount}" FontSize="13" LineBreakMode="TailTruncation" TextColor="#334155" />
                            <Label Grid.Column="1" Text="{Binding ClientNetworkCode}" IsVisible="{Binding HasClientNetworkCode}" FontSize="12" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" IsVisible="{Binding HasDifferentInvoicedAccount}">
                            <Label Text="{Binding DisplayInvoicedAccount}" FontSize="12" LineBreakMode="TailTruncation" TextColor="#475569" />
                            <Label Grid.Column="1" Text="Facturé" FontSize="12" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <CollectionView x:Name="CustomerBillingCollection" Grid.Row="1" Margin="12,0,12,12">
                <CollectionView.EmptyView>
                    <Label Text="Aucune facture client à afficher." FontSize="13" TextColor="#64748B" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Margin="20" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="14,12" StrokeThickness="1" Stroke="#E2E8F0" BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <VerticalStackLayout Spacing="8" IsVisible="{Binding Source={RelativeSource AncestorType={x:Type local:CustomerBillingListView}}, Path=ShowRepeatedHeader}">
                                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                                        <Label Grid.Column="0" Text="{Binding CustomerBillingId}" FontAttributes="Bold" FontSize="15" TextColor="#16A34A" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#EEF7FF" Padding="8,4" VerticalOptions="Center" HorizontalOptions="Center">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                            <Label Text="{Binding Warehouse}" FontSize="11" TextColor="#2563EB" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" />
                                        </Border>
                                        <Label Grid.Column="2" Text="{Binding DisplayCreationDate}" FontSize="12" TextColor="#64748B" VerticalOptions="Center" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" IsVisible="{Binding Source={RelativeSource AncestorType={x:Type local:CustomerBillingListView}}, Path=ShowHeaderTotals}">
                                        <Label Text="{Binding DisplayTotalHTBase, StringFormat='HT : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#0F172A" LineBreakMode="NoWrap" />
                                        <Label Grid.Column="1" Text="{Binding DisplayTotalTVA, StringFormat='TVA : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" />
                                        <Label Grid.Column="2" Text="{Binding DisplayTotalTTC, StringFormat='TTC : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#DC2626" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                    </Grid>

                                    <VerticalStackLayout Spacing="3" IsVisible="{Binding ShouldShowCustomerBlock}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <Label Text="{Binding DisplayDeliveredAccount}" FontSize="13" LineBreakMode="TailTruncation" TextColor="#334155" />
                                            <Label Grid.Column="1" Text="{Binding ClientNetworkCode}" IsVisible="{Binding HasClientNetworkCode}" FontSize="12" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" IsVisible="{Binding HasDifferentInvoicedAccount}">
                                            <Label Text="{Binding DisplayInvoicedAccount}" FontSize="12" LineBreakMode="TailTruncation" TextColor="#475569" />
                                            <Label Grid.Column="1" Text="Facturé" FontSize="12" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6" Margin="0,2,0,0" IsVisible="{Binding Source={RelativeSource AncestorType={x:Type local:CustomerBillingListView}}, Path=ShowDetailedView}">
                                    <BoxView HeightRequest="0.5" Color="#E5EAF0" IsVisible="{Binding Source={RelativeSource AncestorType={x:Type local:CustomerBillingListView}}, Path=ShowRepeatedHeader}" />
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="0,2">
                                        <Label Grid.Column="0" Text="{Binding ProductCode}" FontSize="12" FontAttributes="Bold" TextColor="#16A34A" HorizontalOptions="Start" LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="1" Text="{Binding DeliveryType}" FontSize="12" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="2" Text="{Binding DisplayQuantity, StringFormat='Qté : {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#0F172A" HorizontalTextAlignment="End" MinimumWidthRequest="64" LineBreakMode="NoWrap" />
                                    </Grid>

                                    <Label Text="{Binding ProductLabel, Converter={StaticResource ClientOrderCodeDisplayConverter}, ConverterParameter=58}"
                                           InputTransparent="{Binding ProductLabel, Converter={StaticResource ClientOrderCodeInputTransparentConverter}, ConverterParameter=58}"
                                           FontSize="12"
                                           TextColor="#334155"
                                           LineBreakMode="TailTruncation">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnProductLabelTapped" CommandParameter="{Binding ProductLabel}" />
                                        </Label.GestureRecognizers>
                                    </Label>

                                    <Border StyleId="ProductLabelPopup" IsVisible="False" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="8,5">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                        <Label Text="{Binding ProductLabel}" FontSize="11" TextColor="#0F172A" LineBreakMode="WordWrap" />
                                    </Border>

                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="0,2">
                                        <Label Grid.Column="0" Text="{Binding DeliveryNumber}" FontSize="11" FontAttributes="Bold" TextColor="#0F172A" LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="1" Text="{Binding SorderClientCode, Converter={StaticResource ClientOrderCodeDisplayConverter}, ConverterParameter=24}"
                                               InputTransparent="{Binding SorderClientCode, Converter={StaticResource ClientOrderCodeInputTransparentConverter}, ConverterParameter=24}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#DC2626"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="TailTruncation">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnSorderClientCodeTapped" CommandParameter="{Binding SorderClientCode}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                        <Label Grid.Column="2" Text="{Binding DisplayInvoiceDate}" FontSize="11" TextColor="#64748B" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                    </Grid>

                                    <Border StyleId="SorderClientCodePopup" IsVisible="False" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="8,5">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                        <Label Text="{Binding SorderClientCode}" FontSize="11" TextColor="#0F172A" LineBreakMode="WordWrap" />
                                    </Border>

                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                        <Label Text="{Binding DisplayTotalHTBase, StringFormat='HT : {0}'}" FontSize="11" FontAttributes="Bold" TextColor="#0F172A" LineBreakMode="NoWrap" />
                                        <Label Grid.Column="1" Text="{Binding DisplayTotalTVA, StringFormat='TVA : {0}'}" FontSize="11" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" />
                                        <Label Grid.Column="2" Text="{Binding DisplayTotalTTC, StringFormat='TTC : {0}'}" FontSize="11" FontAttributes="Bold" TextColor="#DC2626" HorizontalTextAlignment="End" LineBreakMode="NoWrap" />
                                    </Grid>
                                </VerticalStackLayout>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,6,0,0" IsVisible="{Binding Source={RelativeSource AncestorType={x:Type local:CustomerBillingListView}}, Path=ShowHeaderButtons}">
                                    <Button Text="Lignes" Clicked="OnViewDetailClicked" CommandParameter="{Binding .}" BackgroundColor="#F1F5F9" TextColor="#0F172A" FontAttributes="Bold" CornerRadius="14" HeightRequest="38" />
                                    <Button Grid.Column="1" Text="PDF" Clicked="OnDownloadPdfClicked" CommandParameter="{Binding .}" BackgroundColor="#16A34A" TextColor="White" FontAttributes="Bold" CornerRadius="14" HeightRequest="38" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <Grid x:Name="ApiLoadingOverlay" Grid.RowSpan="2" IsVisible="False" InputTransparent="False" BackgroundColor="#80F8FAFC" ZIndex="10">
            <Border Padding="22,20" BackgroundColor="White" Stroke="#D9E2EC" StrokeThickness="1" HorizontalOptions="Center" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <ActivityIndicator x:Name="ApiActivityIndicator" IsVisible="False" IsRunning="False" Color="#16A34A" WidthRequest="44" HeightRequest="44" HorizontalOptions="Center" />
                    <Label Text="Chargement..." FontSize="13" FontAttributes="Bold" TextColor="#0F172A" HorizontalTextAlignment="Center" />
                    <Label Text="Veuillez patienter" FontSize="11" TextColor="#64748B" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
