<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AGRA_EASY_MOBILE"
             x:Class="AGRA_EASY_MOBILE.CustomerBillingFilterView"
             BackgroundColor="#F6F8FB"
             Title="Filtrer les factures">
    <Grid RowDefinitions="*,Auto" Padding="20,20,20,18">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="16">
                <Border BackgroundColor="#EAF6FF" StrokeThickness="0" Padding="18,16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Filtrer les factures" FontSize="20" FontAttributes="Bold" TextColor="#0F172A" />
                        <Label Text="Saisissez uniquement les critères utiles à la recherche." FontSize="13" TextColor="#64748B" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Période" FontSize="15" FontAttributes="Bold" TextColor="#16A34A" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Grid.Column="0" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="De" FontSize="11" TextColor="#64748B" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <local:BorderlessEntry x:Name="StartDateEntry" Placeholder="jj/mm/aaaa" Keyboard="Numeric" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" />
                                        <Grid Grid.Column="1" WidthRequest="38" HeightRequest="34">
                                            <ImageButton Source="ic_calendar.png" BackgroundColor="#E0F2FE" CornerRadius="12" Padding="7" Aspect="AspectFit" />
                                            <local:BorderlessDatePicker x:Name="StartDatePicker" DateSelected="OnStartDateSelected" BackgroundColor="Transparent" Opacity="0.01" />
                                        </Grid>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Jusqu'à" FontSize="11" TextColor="#64748B" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <local:BorderlessEntry x:Name="EndDateEntry" Placeholder="jj/mm/aaaa" Keyboard="Numeric" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" />
                                        <Grid Grid.Column="1" WidthRequest="38" HeightRequest="34">
                                            <ImageButton Source="ic_calendar.png" BackgroundColor="#E0F2FE" CornerRadius="12" Padding="7" Aspect="AspectFit" />
                                            <local:BorderlessDatePicker x:Name="EndDatePicker" DateSelected="OnEndDateSelected" BackgroundColor="Transparent" Opacity="0.01" />
                                        </Grid>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Critères" FontSize="15" FontAttributes="Bold" TextColor="#16A34A" />
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="12">
                            <Border Grid.Row="0" Grid.Column="0" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <Grid ColumnDefinitions="*,42" ColumnSpacing="8">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="Article" FontSize="11" TextColor="#64748B" />
                                        <local:BorderlessEntry x:Name="EntryProduct" Placeholder="Référence" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" VerticalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                    <Grid Grid.Column="1" WidthRequest="42" RowDefinitions="*,*" RowSpacing="2" VerticalOptions="Fill">
                                        <Border Grid.Row="0" BackgroundColor="#DCFCE7" StrokeThickness="0" Padding="0" Margin="0,1,0,1" HorizontalOptions="Fill" VerticalOptions="Fill">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="9" /></Border.StrokeShape>
                                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnScanProductBarcodeClicked" /></Border.GestureRecognizers>
                                            <Image Source="ic_barcode_scan.png" WidthRequest="17" HeightRequest="15" HorizontalOptions="Center" VerticalOptions="Center" Aspect="AspectFit" />
                                        </Border>
                                        <Border Grid.Row="1" BackgroundColor="#E0F2FE" StrokeThickness="0" Padding="0" Margin="0,1,0,1" HorizontalOptions="Fill" VerticalOptions="Fill">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="9" /></Border.StrokeShape>
                                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnSelectProductClicked" /></Border.GestureRecognizers>
                                            <Image Source="ic_search_product.png" WidthRequest="17" HeightRequest="15" HorizontalOptions="Center" VerticalOptions="Center" Aspect="AspectFit" />
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="N° commande client" FontSize="11" TextColor="#64748B" />
                                    <local:BorderlessEntry x:Name="EntryClientSorder" Placeholder="N° commande" Keyboard="Text" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="N° BL / retour" FontSize="11" TextColor="#64748B" />
                                    <local:BorderlessEntry x:Name="EntryDeliveryNumber" Placeholder="N° document" Keyboard="Text" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" />
                                </VerticalStackLayout>
                            </Border>

                            <Border x:Name="DeliveredAccountCodeContainer" Grid.Row="2" Grid.Column="0" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <Grid RowDefinitions="Auto,34" ColumnDefinitions="*,38" ColumnSpacing="8">
                                    <Label Grid.Row="0" Grid.ColumnSpan="2" Text="Code client livré" FontSize="11" TextColor="#64748B" />
                                    <local:BorderlessEntry x:Name="EntryAccountCode" Grid.Row="1" Grid.Column="0" Placeholder="Ex : 000181" Keyboard="Text" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" VerticalTextAlignment="Center" />
                                    <ImageButton x:Name="SelectDeliveredClientButton" Grid.Row="1" Grid.Column="1" Source="ic_user.png" Clicked="OnSelectDeliveredClientClicked" BackgroundColor="#E0F2FE" CornerRadius="12" WidthRequest="38" HeightRequest="34" Padding="7" Aspect="AspectFit" />
                                </Grid>
                            </Border>

                            <Border x:Name="InvoicedAccountCodeContainer" Grid.Row="2" Grid.Column="1" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <Grid RowDefinitions="Auto,34" ColumnDefinitions="*,38" ColumnSpacing="8">
                                    <Label Grid.Row="0" Grid.ColumnSpan="2" Text="Code client facturé" FontSize="11" TextColor="#64748B" />
                                    <local:BorderlessEntry x:Name="EntryInvoicedAccountCode" Grid.Row="1" Grid.Column="0" Placeholder="Ex : 000181" Keyboard="Text" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" VerticalTextAlignment="Center" />
                                    <ImageButton x:Name="SelectInvoicedClientButton" Grid.Row="1" Grid.Column="1" Source="ic_user.png" Clicked="OnSelectInvoicedClientClicked" BackgroundColor="#E0F2FE" CornerRadius="12" WidthRequest="38" HeightRequest="34" Padding="7" Aspect="AspectFit" />
                                </Grid>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12" Padding="0,14,0,0">
            <Button Text="ANNULER" Clicked="OnCancelClicked" BackgroundColor="#E2E8F0" TextColor="#334155" FontAttributes="Bold" CornerRadius="18" HeightRequest="50" />
            <Button Grid.Column="1" Text="VALIDER" Clicked="OnApplyFilterClicked" BackgroundColor="#16A34A" TextColor="White" FontAttributes="Bold" CornerRadius="18" HeightRequest="50" />
        </Grid>
    </Grid>
</ContentPage>
