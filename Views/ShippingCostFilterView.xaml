<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AGRA_EASY_MOBILE"
             x:Class="AGRA_EASY_MOBILE.ShippingCostFilterView"
             BackgroundColor="#F6F8FB"
             Title="Filtrer les frais de port">
    <Grid RowDefinitions="*,Auto" Padding="20,20,20,18">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="16">
                <Border BackgroundColor="#EAF6FF" StrokeThickness="0" Padding="18,16"><Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape><VerticalStackLayout Spacing="6"><Label Text="Filtrer les frais de port" FontSize="20" FontAttributes="Bold" TextColor="#0F172A" /><Label Text="Renseignez au moins un client, un BL de frais de port ou un BL marchandise." FontSize="13" TextColor="#64748B" /></VerticalStackLayout></Border>
                <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" Padding="16"><Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape><VerticalStackLayout Spacing="12"><Label Text="Période" FontSize="15" FontAttributes="Bold" TextColor="#16A34A" /><Grid ColumnDefinitions="*,*" ColumnSpacing="12"><Border Grid.Column="0" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8"><Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape><VerticalStackLayout Spacing="2"><Label Text="De" FontSize="11" TextColor="#64748B" /><Grid ColumnDefinitions="*,32" ColumnSpacing="4"><local:BorderlessEntry x:Name="StartDateEntry" Placeholder="jj/mm/aaaa" Keyboard="Numeric" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" /><Grid Grid.Column="1" WidthRequest="32" HeightRequest="34"><ImageButton Source="ic_calendar.png" BackgroundColor="#E0F2FE" CornerRadius="12" Padding="6" Aspect="AspectFit" /><local:BorderlessDatePicker x:Name="StartDatePicker" DateSelected="OnStartDateSelected" BackgroundColor="Transparent" Opacity="0.01" /></Grid></Grid></VerticalStackLayout></Border><Border Grid.Column="1" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8"><Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape><VerticalStackLayout Spacing="2"><Label Text="Jusqu'à" FontSize="11" TextColor="#64748B" /><Grid ColumnDefinitions="*,32" ColumnSpacing="4"><local:BorderlessEntry x:Name="EndDateEntry" Placeholder="jj/mm/aaaa" Keyboard="Numeric" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" /><Grid Grid.Column="1" WidthRequest="32" HeightRequest="34"><ImageButton Source="ic_calendar.png" BackgroundColor="#E0F2FE" CornerRadius="12" Padding="6" Aspect="AspectFit" /><local:BorderlessDatePicker x:Name="EndDatePicker" DateSelected="OnEndDateSelected" BackgroundColor="Transparent" Opacity="0.01" /></Grid></Grid></VerticalStackLayout></Border></Grid></VerticalStackLayout></Border>
                <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" Padding="16"><Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape><VerticalStackLayout Spacing="12"><Label Text="Critères" FontSize="15" FontAttributes="Bold" TextColor="#16A34A" /><Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="12"><Border Grid.Row="0" Grid.Column="0" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8"><Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape><VerticalStackLayout Spacing="2"><Label Text="Plateforme" FontSize="11" TextColor="#64748B" /><local:BorderlessPicker x:Name="PickerWarehouse" Title="Toutes" TitleColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" /></VerticalStackLayout></Border><Border x:Name="AccountCodeContainer" Grid.Row="1" Grid.Column="1" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8"><Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape><Grid RowDefinitions="Auto,34" ColumnDefinitions="*,38" ColumnSpacing="8"><Label Grid.Row="0" Grid.ColumnSpan="2" Text="Code client" FontSize="11" TextColor="#64748B" /><local:BorderlessEntry x:Name="EntryAccountCode" Grid.Row="1" Grid.Column="0" Placeholder="Ex : 000181" Keyboard="Text" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" VerticalTextAlignment="Center" /><ImageButton x:Name="SelectClientButton" Grid.Row="1" Grid.Column="1" Source="ic_user.png" Clicked="OnSelectClientClicked" BackgroundColor="#E0F2FE" CornerRadius="12" WidthRequest="38" HeightRequest="34" Padding="7" Aspect="AspectFit" /></Grid></Border><Border Grid.Row="1" Grid.Column="0" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8"><Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape><VerticalStackLayout Spacing="2"><Label Text="BL frais de port" FontSize="11" TextColor="#64748B" /><local:BorderlessEntry x:Name="EntryShippingCostDeliveryNumber" Placeholder="N° BL frais" Keyboard="Text" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" /></VerticalStackLayout></Border><Border Grid.Row="0" Grid.Column="1" Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="12,8"><Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape><VerticalStackLayout Spacing="2"><Label Text="BL marchandise" FontSize="11" TextColor="#64748B" /><local:BorderlessEntry x:Name="EntryTurnoverDeliveryNumber" Placeholder="N° BL marchandise" Keyboard="Text" PlaceholderColor="#94A3B8" TextColor="#0F172A" BackgroundColor="Transparent" HeightRequest="34" /></VerticalStackLayout></Border></Grid></VerticalStackLayout></Border>
            </VerticalStackLayout>
        </ScrollView>
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12" Padding="0,14,0,0"><Button Text="Annuler" Clicked="OnCancelClicked" BackgroundColor="#E2E8F0" TextColor="#0F172A" FontAttributes="Bold" CornerRadius="14" HeightRequest="46" /><Button Grid.Column="1" Text="Appliquer" Clicked="OnApplyFilterClicked" BackgroundColor="#16A34A" TextColor="White" FontAttributes="Bold" CornerRadius="14" HeightRequest="46" /></Grid>
    </Grid>
</ContentPage>
