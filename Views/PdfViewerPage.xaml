<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AGRA_EASY_MOBILE.PdfViewerPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <Grid>
        <Grid x:Name="ViewerHost" BackgroundColor="White" />

        <Label x:Name="FallbackLabel"
               IsVisible="False"
               Margin="24"
               Padding="18,14"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               TextColor="White"
               BackgroundColor="#B3000000"
               FontSize="14"
               LineBreakMode="WordWrap"
               HorizontalOptions="Center"
               VerticalOptions="Center" />

        <HorizontalStackLayout HorizontalOptions="End"
                               VerticalOptions="Start"
                               Margin="0,18,18,0"
                               Spacing="12">
            <Border BackgroundColor="#2563EB"
                    StrokeThickness="0"
                    WidthRequest="54"
                    HeightRequest="54"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="27" />
                </Border.StrokeShape>
                <Button Text="↓"
                        Clicked="OnSaveClicked"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        Padding="0"
                        WidthRequest="54"
                        HeightRequest="54" />
            </Border>

            <Border BackgroundColor="#7C3AED"
                    StrokeThickness="0"
                    WidthRequest="54"
                    HeightRequest="54"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="27" />
                </Border.StrokeShape>
                <Button Text="↗"
                        Clicked="OnShareClicked"
                        FontSize="26"
                        FontAttributes="Bold"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        Padding="0"
                        WidthRequest="54"
                        HeightRequest="54" />
            </Border>

            <Border BackgroundColor="#DC2626"
                    StrokeThickness="0"
                    WidthRequest="54"
                    HeightRequest="54"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="27" />
                </Border.StrokeShape>
                <Button Text="✕"
                        Clicked="OnCloseClicked"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        Padding="0"
                        WidthRequest="54"
                        HeightRequest="54" />
            </Border>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
