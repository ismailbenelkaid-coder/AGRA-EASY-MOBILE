<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:scanner="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
             x:Class="AGRA_EASY_MOBILE.BarcodeScannerPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">
    <Grid>
        <scanner:CameraView x:Name="BarcodeCamera"
                            CameraEnabled="False"
                            VibrationOnDetected="True"
                            ViewfinderMode="True"
                            AimMode="False"
                            OnDetectionFinished="BarcodeCamera_OnDetectionFinished" />

        <Grid BackgroundColor="#33000000" />

        <Border HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="280"
                HeightRequest="180"
                Stroke="#D1D5DB"
                StrokeThickness="2"
                BackgroundColor="Transparent">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
            </Border.StrokeShape>
            <Grid>
                <BoxView x:Name="ScanLine"
                         HeightRequest="3"
                         Color="#16A34A"
                         HorizontalOptions="Fill"
                         VerticalOptions="Start" />
            </Grid>
        </Border>

        <VerticalStackLayout VerticalOptions="Start" Padding="20,28,20,0" Spacing="8">
            <Label Text="Scanner un code-barres"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <Label Text="Présentez le code-barres dans le cadre. La lecture se valide automatiquement."
                   FontSize="14"
                   TextColor="#E5E7EB"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <Button Text="Annuler"
                Clicked="OnCancelClicked"
                BackgroundColor="#E2E8F0"
                TextColor="#0F172A"
                FontAttributes="Bold"
                CornerRadius="20"
                HeightRequest="50"
                WidthRequest="160"
                VerticalOptions="End"
                HorizontalOptions="Center"
                Margin="0,0,0,30" />
    </Grid>
</ContentPage>
